#--------------------------------------------------------------------
# Exemple de fichier de configuration d'environnement
#
# Ce fichier peut servir de point de départ pour vos propres
# fichiers .env personnalisés. Il contient la plupart des paramètres
# disponibles dans une installation par défaut.
#
# Par défaut, tous les paramètres sont commentés. Pour activer
# un paramètre, décommentez-le en supprimant le '#'
# au début de la ligne.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONNEMENT
#--------------------------------------------------------------------

# CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APPLICATION
#--------------------------------------------------------------------

# app.baseURL = ''
# Si vous avez des problèmes avec `.`, vous pouvez aussi utiliser `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false


#--------------------------------------------------------------------
# BASE DE DONNÉES
#--------------------------------------------------------------------

database.default.DBDriver = SQLite3
database.default.database = database.db
database.default.DBPrefix = coop_

